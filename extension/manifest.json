{
  "manifest_version": 3,
  "name": "Echo AI Security",
  "version": "1.0",
  "description": "AI-powered phishing detection with real-time analysis",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],
  "icons": {
  "16":  "icons/icon16.png",
  "48":  "icons/icon48.png",
  "128": "icons/icon128.png"
},

  "host_permissions": [
    "https://echoai-security-webextension.onrender.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },
  "default_icon": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}